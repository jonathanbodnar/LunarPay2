#This file is auto copied on dist when build for serving the app without conflicting with codeigniter routing

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /customer-hub/

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

