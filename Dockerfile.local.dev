# Use the official PHP 7.4.7 Apache image as a base
FROM php:7.4.7-apache

RUN sed -i 's/deb.debian.org/archive.debian.org/g' /etc/apt/sources.list \
 && sed -i 's/security.debian.org/archive.debian.org/g' /etc/apt/sources.list \
 && echo 'Acquire::Check-Valid-Until "false";' > /etc/apt/apt.conf.d/99no-check-valid-until


# Install required extensions and tools
RUN apt-get update && apt-get install -y \
    libpng-dev \
    libjpeg-dev \
    libfreetype6-dev \
    libzip-dev \
    libpq-dev \
    zip \
    unzip \
    git \
    cron \
    tzdata \
    && curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install gd zip pdo pdo_mysql pdo_pgsql mysqli bcmath

ENV TZ=America/Chicago
RUN ln -sf /usr/share/zoneinfo/$TZ /etc/localtime \
    && echo $TZ > /etc/timezone

# Enable Apache mod_rewrite and fix MPM configuration
RUN a2dismod mpm_event mpm_worker && \
    a2enmod mpm_prefork rewrite

# Set the ServerName globally for removing: AH00558: apache2: Could not reliably determine the server's fully qualified domain name, using [IP] Set the 'ServerName' directive globally
RUN echo "ServerName localhost" >> /etc/apache2/apache2.conf

# Set the working directory in the container
WORKDIR /var/www/html

# Copy the CodeIgniter application files into the container
COPY . .

# Set permissions for the application
RUN chown -R www-data:www-data /var/www/html

#Set specific permissions for the uploads/invoices directory | uploads are stored in the container not reflected on the host
RUN chown -R www-data:www-data /var/www/html/application/uploads \
 && chmod -R 755 /var/www/html/application/uploads

# Set ownership and permissions for logs folder
RUN chown -R www-data:www-data /var/www/html/application/logs \
 && chmod -R 755 /var/www/html/application/logs

 # Set ownership and permissions for migrations folder
RUN chown -R www-data:www-data /var/www/html/application/migrations \
&& chmod -R 775 /var/www/html/application/migrations

# Copy the custom php.ini file to the PHP configuration directory
COPY php.ini /usr/local/etc/php/conf.d/

# Remove vendor directory and composer.lock file to ensure a fresh install
RUN rm -rf /var/www/html/application/vendor /var/www/html/application/composer.lock

# Set the working directory to /var/www/html/application to run composer install
#WORKDIR /var/www/html/application

# Install Composer dependencies, however the bind mount will overwrite the vendor directory on development. On dev, run composer install from the container
RUN composer install --working-dir=/var/www/html/application

# Install Node.js 23.x
RUN curl -fsSL https://deb.nodesource.com/setup_23.x | bash - \
  && apt-get install -y nodejs

# Build the React frontend
RUN npm install --prefix /var/www/html/customer-hub && npm run build --prefix /var/www/html/customer-hub

# Go back to the main working directory
WORKDIR /var/www/html

# Copy the cron job configuration file into the container
COPY cronjob /etc/cron.d/my-cron-job
# Give the cron job the correct permissions
RUN chmod 0644 /etc/cron.d/my-cron-job
# Apply the cron job by installing it into crontab
RUN crontab /etc/cron.d/my-cron-job

# Copy and setup entrypoint script
COPY docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Expose port 80 for the web server (PORT can be overridden by environment variable)
EXPOSE 80
ENV PORT=80

# Use custom entrypoint that fixes MPM at runtime
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]


